&НаСервере
Процедура ОтобратьНаСервере()  
	Запрос = Новый Запрос;
	ЗАпрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 10
	|Док.Ссылка КАК Заказ,
	|Док.Проведен,
	|Док.Статус,
	|Док.Дата 
	|ПОМЕСТИТЬ Заказы
	|ИЗ Документ.ЗаказКлиента КАК Док
	|УПОРЯДОЧИТЬ ПО Док.Ссылка.Дата УБЫВ 
	|;
	| ВЫБРАТЬ ПЕРВЫЕ 10000
	|	ВерсииОбъектов.Объект КАК Объект,
	|	ВерсииОбъектов.НомерВерсии КАК НомерВерсии,
	|	ВерсииОбъектов.ВерсияОбъекта КАК ВерсияОбъекта,
	|	ВерсииОбъектов.ДатаВерсии,
	|	ВерсииОбъектов.АвторВерсии
	|ПОМЕСТИТЬ ВерсииВсе
	|ИЗ
	|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
	|		ГДЕ ВерсииОбъектов.Объект В (ВЫБРАТЬ Заказы.Заказ ИЗ Заказы КАК Заказы)
    |;
	|ВЫБРАТЬ 
	|Заказы.Заказ,
	|Заказы.Проведен,
	|Заказы.Статус,
	|Заказы.Дата, 
	|ВерсииВсе.НомерВерсии, ВерсииВсе.ДатаВерсии ,ВерсииВсе.ВерсияОбъекта
	//	|ПОМЕСТИТЬ Заказы
	|ИЗ Заказы КАК Заказы 
	|ЛЕВОЕ СОЕДИНЕНИЕ  ВерсииВсе КАК ВерсииВсе ПО ВерсииВсе.Объект = Заказы.Заказ И ВерсииВсе.ДатаВерсии<Заказы.Дата

	|УПОРЯДОЧИТЬ ПО Заказы.Дата УБЫВ 
	|";
	МассСтрок = Новый Массив;
	Результат = Запрос.Выполнить().Выгрузить();
	Для каждого стр из Результат Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр);  
		ДатаВВерсии = "";
		Попытка
			ВерсияДвоичная = СК.ВерсияОбъекта.Получить();     
			MD5 = ПолучитьMD5_Сервер(ВерсияДвоичная);
			ВерсияОбъекта = ПолучитьОбъектИзXML(ВерсияДвоичная);  
			Если НЕ ВерсияОбъекта = Неопределено Тогда   
				ДатаВВерсии = ВерсияОбъекта.Дата;
			КонецЕсли;     
		Исключение
		КонецПопытки;
		СК.Вставить("ДатаВВерсии",ДатаВВерсии);
		МассСтрок.Добавить(СК);
	КонецЦикла;
	
	ПостроитьТаблицуДанных(МассСтрок);
КонецПроцедуры

&НаКлиенте
Процедура Отобрать(Команда)
	ОтобратьНаСервере();
КонецПроцедуры
