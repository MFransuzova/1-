&НаСервере
Процедура fC_01_ДобавитьРеквизитыФормы()    
		
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("Объект",Объект.Ссылка);
	Запрос.Текст = "
	|ВЫБРАТЬ
	|ДопСведения.Объект,
	|ДопСведения.Значение,
	|ДопСведения.Свойство.ИдентификаторДляФормул КАК ИД
	|ИЗ РегистрСведений.ДополнительныеСведения КАК ДопСведения   
	|ГДЕ ДопСведения.Объект = &Объект
	|";
	Резуьтат = Запрос.Выполнить().Выгрузить();  
	СтруктураРеквизитов = Новый Структура; 
	МассивДопРеквизитов = Новый Массив;
	
	Для каждого стр из Резуьтат Цикл   
		ИД =СокрЛП(стр.ИД);   
		СписокЗначенийВыбора = Новый СписокЗначений;
		СписокЗначенийВыбора.Добавить(стр.Значение);
		ДБ_ДобавлениеРеквизитовФормы(ИД,МассивДопРеквизитов,СписокЗначенийВыбора);
		СтруктураРеквизитов.Вставить(ИД,Строка(стр.Значение)); 
	КонецЦикла;
	ЗаполнитьЗначенияСвойств(ЭтаФорма,СтруктураРеквизитов);
	
КонецПроцедуры
