	ГруппаЭл = Элементы.ГруппаРежимРасчетаСписанияВПроизводство;
    
	НовыйРеквизит = Новый РеквизитФормы(ИД,Новый ОписаниеТипов("Строка"));   
	МассивДопРеквизитов.Добавить(НовыйРеквизит);               
	ЭтаФорма.ИзменитьРеквизиты(МассивДопРеквизитов);

	НовыйЭлемент = Элементы.Добавить("ДБ_"+ИД, Тип("ПолеФормы"),ГруппаЭл);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
	//НовыйЭлемент.Заголовок = "Код ЦФО";   
    НовыйЭлемент.ПутьКДанным = ИД; 
	//НовыйЭлемент.РежимВыбораИзСписка = Истина;
	//НовыйЭлемент.КнопкаВыбораИЗСписка = Истина; 
	НовыйЭлемент.УстановитьДействие("ПриИзменении","ДБ_ИзменитьДопСведения");  
	НовыйЭлемент.УстановитьДействие("НачалоВыбораИзСписка","ДБ_ВыборИзСпискаДопСведения");
	Элементы.Переместить(НовыйЭлемент,ГруппаЭл,ГруппаЭл.ПодчиненныеЭлементы[0]);
	ДБ_ЗаполнитьСписокЗначенийИД(ИД);  
	Попытка  
		НовыйЭлемент.РежимВыбораИзСписка = Истина;
	Исключение
	КонецПопытки;
	
    //Элементы[ИД].СписокВыбора = СписокЗначенийВыбора;

