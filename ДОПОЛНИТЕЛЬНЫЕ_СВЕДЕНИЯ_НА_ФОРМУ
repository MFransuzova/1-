Процедура ДБ_ЗаполнитьСписокЗначенийИД(ИД)  
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ИД",ИД); 
	Запрос.Текст = "ВЫБРАТЬ   
	|Спр.Ссылка,
	|Спр.Ссылка.Наименование КАК Значение
	|ИЗ Справочник.ЗначенияСвойствОбъектов КАК Спр
	|ГДЕ Спр.Владелец.ИдентификаторДляФормул = &ИД
	|";    

	Результат = Запрос.Выполнить().Выгрузить();     
	СписокЗначенийВыбора = Новый СписокЗначений;
    Элементы["ДБ_"+ИД].СписокВыбора.Очистить();
	Для каждого стр из Результат Цикл  
		
		Элементы["ДБ_"+ИД].СписокВыбора.Добавить(стр.Значение);  
	КонецЦикла;	
КонецПроцедуры

