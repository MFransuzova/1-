Процедура ДБ_ИзменитьДопСвойство(ИД)  
	теОбъект = РеквизитФормыВЗначение("Объект");
	Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("ИдентификаторДляФормул",ИД);
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Объект",теОбъект);
	СтруктураОтбора.Вставить("Свойство",Свойство);  
	НаборЗаписей = РегистрыСведений.ДополнительныеСведения.СоздатьНаборЗаписей();
	//НаборЗаписей.Отбор(СтруктураОтбора);
	НаборЗаписей.Отбор.Свойство.Установить(Свойство);  
	НаборЗаписей.Отбор.Объект.Установить(теОбъект.Ссылка);

	НаборЗаписей.Прочитать();
	Для Каждого Запись Из НаборЗаписей Цикл
			ЗначениеСвойства = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(ЭтаФорма[ИД],,,Свойство);
			//ДБ_ЗаполнитьСписокЗначенийИД(ИД,ЗначениеСвойства) ;
			
			Если ЗначениеСвойства <> Неопределено Тогда
				Запись.Значение = ЗначениеСвойства;
			КонецЕсли;
	КонецЦикла;
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
	
КонецПроцедуры

