&НаКлиенте
Процедура ДБ_ВыборПолучателей(Элемент, ДанныеВыбора, СтандартнаяОбработка) Экспорт     
	СтандартнаяОбработка = Ложь;                    
	ПараметрыПодбора = Новый Структура;
	ПараметрыПодбора.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыПодбора.Вставить("МножественныйВыбор", Истина);      
	ПараметрыПодбора.Вставить("Исполнитель", ЭтаФорма.СписокПользователй); 
	АЛЕАН_ОповещениеЗакрытиеВыбора = Новый ОписаниеОповещения("АЛЕАН_ОповещениеЗакрытиеВыбора",ЭтотОбъект); 
	//ПараметрыПодбора.Вставить("Оповещение",АЛЕАН_ОповещениеЗакрытиеВыбора);
	
	Если НЕ ЭтаФорма.МассивПолучателей.Количество()=0 Тогда
		Оповещение = Новый ОписаниеОповещения("ВопросФормироватьСписокПолучателей", ЭтотОбъект,ПараметрыПодбора);
		ТекстВопроса = НСтр("ru = 'Очистить список получателей?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ОткрытьФорму("ОбщаяФорма.АЛЕАН_Форма_ПодборПолучателей", ПараметрыПодбора, ЭтаФорма,,,,АЛЕАН_ОповещениеЗакрытиеВыбора); 
	КонецЕсли;
КонецПроцедуры  
