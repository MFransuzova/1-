
&НаСервере
Процедура ДБ_ДобавлениеРеквизитовФормы(ИД,МассивДопРеквизитов,СписокЗначенийВыбора)
	ГруппаЭл = Элементы.ГруппаИсполнение;
	
	НовыйРеквизит = Новый РеквизитФормы(ИД,Новый ОписаниеТипов("Строка")); 
	МассивДопРеквизитов.Добавить(НовыйРеквизит); 
	ЭтаФорма.ИзменитьРеквизиты(МассивДопРеквизитов);
	
	НовыйЭлемент = Элементы.Добавить("ДБ_"+ИД, Тип("ПолеФормы"),ГруппаЭл);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
	НовыйЭлемент.ПутьКДанным = "МассивПолучателей";
	НовыйЭлемент.УстановитьДействие("ПриИзменении","ДБ_ИзменитьДопСведения");  
	НовыйЭлемент.УстановитьДействие("НачалоВыбораИзСписка","ДБ_ВыборПолучателей");   
	НовыйЭлемент.УстановитьДействие("НачалоВыбора","ДБ_ВыборПолучателей");    
	Элементы.Переместить(НовыйЭлемент,ГруппаЭл,ГруппаЭл.ПодчиненныеЭлементы[0]);
	Попытка  
		текОб= РеквизитФормыВЗначение("Объект");
		СпВр = текОб.СодержаниеПредмета.Получить(); 
		Если НЕ СпВр=Неопределено Тогда
			МассивПолучателей = СпВр;
		КонецЕсли;	
	Исключение
	КонецПопытки;
	
КонецПроцедуры

