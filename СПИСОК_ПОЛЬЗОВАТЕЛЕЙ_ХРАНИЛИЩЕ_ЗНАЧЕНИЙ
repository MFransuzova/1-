&НаСервере
Процедура ДБ_ЗаполнитьСписокПолучателей(МассивДанных)  
	Для каждого эл из МассивДанных Цикл     
		Если МассивПолучателей.НайтиПоЗначению(эл)=Неопределено Тогда
			МассивПолучателей.Добавить(эл);                              
		КонецЕсли;
	КонецЦикла;
	АЛЕАН_СписокПользователй = СтрСоединить(МассивДанных,";");
КонецПроцедуры

&НаКлиенте
Процедура АЛЕАН_ОповещениеЗакрытиеВыбора(ВыбранныеДанные, ДополнительныеПараметры) Экспорт  
	Если НЕ ВыбранныеДанные = Неопределено И ТипЗнч(ВыбранныеДанные) = Тип("Структура") Тогда 
		Если ВыбранныеДанные.Свойство("ВыборДанных") Тогда
			ДБ_ЗаполнитьСписокПолучателей(ВыбранныеДанные.ВыборДанных);     
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте

Процедура ВопросФормироватьСписокПолучателей(ВыбранныеДанные, ДополнительныеПараметры) Экспорт  
	Если ВыбранныеДанные =  КодВозвратаДиалога.Да Тогда
		ЭтаФорма.МассивПолучателей.Очистить();             
	КонецЕсли;                               
	АЛЕАН_ОповещениеЗакрытиеВыбора = Новый ОписаниеОповещения("АЛЕАН_ОповещениеЗакрытиеВыбора",ЭтотОбъект); 
	
	ОткрытьФорму("ОбщаяФорма.АЛЕАН_Форма_ПодборПолучателей", ДополнительныеПараметры, ЭтаФорма,,,,АЛЕАН_ОповещениеЗакрытиеВыбора);
КонецПроцедуры	

&НаСервере
Процедура СоздатьЗаданиеПодчиненное(СтруктураПоиска)   
	текОб= РеквизитФормыВЗначение("Объект");
	
	НовоеЗадание = Задачи.ЗадачаИсполнителя.СоздатьЗадачу();  
	ЗаполнитьЗначенияСвойств(НовоеЗадание,текОб);
	ЗаполнитьЗначенияСвойств(НовоеЗадание,СтруктураПоиска); 
	НовоеЗадание.Дата = ТекущаяДата();  
	НовоеЗадание.УстановитьНовыйНомер();
	
	НовоеЗадание.Записать();
	
КонецПроцедуры

&НаСервере
Процедура ОтправкаЗадачПоИсполнителям()
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ЭтаЗадача",Объект.Ссылка);
	Запрос.Текст = "
	|  ВЫБРАТЬ 
	|ЗадачиВсе.Ссылка,
	|ЗадачиВсе.БизнесПроцесс,
	|ЗадачиВсе.Исполнитель
	|ИЗ Задача.ЗадачаИсполнителя КАК ЗадачиВсе
	|ГДЕ ЗадачиВсе.БизнесПроцесс = &ЭтаЗадача
	|";    
	Результат = Запрос.Выполнить().Выгрузить();  
	текОб= РеквизитФормыВЗначение("Объект");
	МассивПолучателейСп = текОб.СодержаниеПредмета.Получить();
	Если НЕ ТипЗнч(МассивПолучателейСп) = Тип("СписокЗначений") Тогда
		Возврат;
	КонецЕсли;  
	Для каждого сп из МассивПолучателейСп Цикл  
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Исполнитель",сп.Значение);
		Найдены = Результат.НайтиСтроки(СтруктураПоиска);
		Если Найдены.Количество()=0 Тогда    
			СтруктураПоиска.Вставить("БизнесПроцесс",Объект.Ссылка);
			СоздатьЗаданиеПодчиненное(СтруктураПоиска);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

