 Функция СортировкаПузырьком(Массив)
    
    Для i = 0 По Массив.ВГраница() Цикл
        Для j = 0 ПО Массив.Вграница() - i - 1 Цикл
            Если Массив[j] > Массив[j + 1] Тогда
                Замена = Массив[j];
                Массив[j] = Массив[j + 1];
                Массив[j + 1] = Замена;
            КонецЕсли;            
        КонецЦикла;        
    КонецЦикла;    
    Возврат Массив;    
КонецФункции
