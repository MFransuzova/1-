&НаСервере
Процедура ДействияНАСвервере(Структура) Экспорт
	ТабДок = Структура.ТД;   
	ТабличныйДокумент = Новый ТабличныйДокумент; 
	ТабличныйДокумент.ВставитьОбласть(ТабДок.Область(), ТабличныйДокумент.Область());  
	
	АдресТЗ = Неопределено;    
	ПоследняяСтрока = ТабДок.ВысотаТаблицы-1;
	ПоследняяКолонка = ТабДок.ШиринаТаблицы;
	ОбластьЯчеек = ТабДок.Область(4, 1, ПоследняяСтрока, ПоследняяКолонка);
	ТабличныйДокумент_ТаблицаЗначений(ТабДок,АдресТЗ,ОбластьЯчеек);  
	Если НЕ АдресТЗ = Неопределено Тогда
		ТаблицаЗначений = ПолучитьИзВременногоХранилища(АдресТЗ);
	Иначе
		ТаблицаЗначений = ТабличныйДокументВТаблицуЗначений(ТабДок);   
	КонецЕсли;
	
	МассивДанных = Новый Массив;   
	МассивМенеджер = Новый Массив;  
	СоответствиеДанных = Новый Соответствие;
	Для каждого стр из ТаблицаЗначений Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр);  
		Если СК.Свойство("Менеджер") Тогда
			Если МассивМенеджер.Найти(СК.Менеджер)=Неопределено Тогда
				МассивМенеджер.Добавить(СК.Менеджер);
			КонецЕсли;  
			Если СоответствиеДанных.Получить(СК.Менеджер)=Неопределено Тогда
				СоответствиеДанных.Вставить(СК.Менеджер,Новый Массив); 
			КонецЕсли;
			Значение = СоответствиеДанных.Получить(СК.Менеджер);
			Значение.Добавить(СК);   
			СоответствиеДанных.Вставить(СК.Менеджер,Значение);
		КонецЕсли;
		
		МассивДанных.Добавить(СК);                 
	КонецЦикла;
	Структура.Вставить("МассивДанных",МассивМенеджер); 
	Структура.Вставить("СоответствиеДанных",СоответствиеДанных);
КонецПроцедуры    


Функция ДанныеБонусов_Т(МассивДанных,стСоответсвие) Экспорт
	
	Поток = Новый ПотокВПамяти;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ПроверятьСтруктуру = Ложь; // 'Истина' только во время отладки
	ЗаписьJSON.ОткрытьПоток(Поток,,, Новый ПараметрыЗаписиJSON(, Символы.Таб)); 
	Для каждого эл из МассивДанных Цикл
		Если эл="" Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		ЗаписьJSON.ЗаписатьИмяСвойства(эл);
		ЗаписьJSON.ЗаписатьНачалоМассива();
		Значения = стСоответсвие.Получить(эл);
		Если НЕ Значения = Неопределено Тогда  
			Для каждого элСк ИЗ  Значения Цикл    
				ЗаписьJSON.ЗаписатьНачалоОбъекта();
				Для каждого ск из элСк Цикл
					Если ск.Ключ = "Менеджер" Тогда
						Продолжить;
					КонецЕсли;
					Значение = ск.Значение;       
					
					Если НЕ ТипЗнч(Значение) = Тип("Строка") 
						ИЛИ  НЕ ТипЗнч(Значение) = Тип("Число") 
						ИЛИ НЕ ТипЗнч(Значение) = Тип("Булево") Тогда
						Значение = Строка(Значение);
					КонецЕсли;
					ЗаписьJSON.ЗаписатьИмяСвойства(ск.Ключ);
					ЗаписьJSON.ЗаписатьЗначение(Значение);
				КонецЦикла;	
				ЗаписьJSON.ЗаписатьКонецОбъекта(); 
			КонецЦикла;
		КонецЕсли;
		
		ЗаписьJSON.ЗаписатьКонецМассива();  
		ЗаписьJSON.ЗаписатьКонецОбъекта();
	КонецЦикла;
	ЗаписьJSON.Закрыть();
	
	СтрокаJSON = ПолучитьСтрокуИзДвоичныхДанных(Поток.ЗакрытьИПолучитьДвоичныеДанные(),"UTF-8");  
	
	Возврат СтрокаJSON;
КонецФункции 


Функция ТабличныйДокументВТаблицуЗначений(ТабДок, НачСтрока = 4, НачКолонка = 1) Экспорт
	
	Высота = ТабДок.ВысотаТаблицы;
	Ширина = ТабДок.ШиринаТаблицы;
	
	Если Высота < НачСтрока Или Ширина < НачКолонка Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Результат = Новый ТаблицаЗначений;
	
	// ----- Заголовки колонок (из строки НачСтрока-1) -----
	СтрЗаголовков = НачСтрока - 1;
	Если СтрЗаголовков >= 1 Тогда
		Для НомКол = НачКолонка По Ширина Цикл
			Заголовок = СокрЛП(ТабДок.Область(СтрЗаголовков, НомКол).Текст);
			Если ПустаяСтрока(Заголовок) Тогда
				Заголовок = "Колонка" + Формат(НомКол, "ЧГ=0");
			КонецЕсли;
			// Все данные из ТД — строки (при необходимости преобразуйте позже)
			Результат.Колонки.Добавить(Заголовок, Новый ОписаниеТипов("Строка"));
		КонецЦикла;
	Иначе
		Для НомКол = НачКолонка По Ширина Цикл
			Результат.Колонки.Добавить("Колонка" + Формат(НомКол, "ЧГ=0"), Новый ОписаниеТипов("Строка"));
		КонецЦикла;
	КонецЕсли;
	
	// ----- Данные (строки начиная с НачСтрока) -----
	Для НомСтр = НачСтрока По Высота Цикл
		НоваяСтрока = Результат.Добавить();
		Для НомКол = НачКолонка По Ширина Цикл
			Значение = ТабДок.Область(НомСтр, НомКол).Текст;
			НоваяСтрока[НомКол - НачКолонка] = Значение;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ТабличныйДокумент_ТаблицаЗначений(ТабДокумент,АдресТЗ,ОбластьЯчеек)    Экспорт
	
	// Создаем описание источника данных на основании области ячеек табличного документа. 
	ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);
	
	// Создаем объект для интеллектуального построения отчетов,
	// указываем источник данных и выполняем построение отчета.
	ПостроительОтчета = Новый ПостроительОтчета;	
	ПостроительОтчета.ИсточникДанных = ИсточникДанных;
	ПостроительОтчета.Выполнить();
	
	// Результат выгружаем в таблицу значений.
	Попытка
		ТабЗначений = ПостроительОтчета.Результат.Выгрузить();
		
		АдресТЗ =  ПоместитьВоВременноеХранилище(ТабЗначений); 
	Исключение
	КонецПопытки;
КонецПроцедуры	

