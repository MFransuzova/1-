 Процедура ВыгрузитьСертификатыНаСервере(МассивДанных)  
	
	// 22.05.2026 1:09 X2
	Запрос = Новый Запрос;
	Запрос.Текст = " 
	|  ВЫБРАТЬ 
	|ОстаткиС.ПодарочныйСертификат ,
	|ОстаткиС.СуммаОСтаток
	|ПОМЕСТИТЬ ОстаткиСертификатов
	|ИЗ  РегистрНакопления.ПодарочныеСертификаты.Остатки КАК ОстаткиС
	|;
	|	ВЫБРАТЬ  
	|УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СпрСерт.Ссылка) КАК ID,
	|СпрСерт.Код КАК KODS,
	|СпрСерт.Наименование КАК NAMES,
	|СпрСерт.Штрихкод КАК BARCODECODE, 
	|СпрСерт.МагнитныйКод КАК MAGNATEDID,
	|СпрСерт.Владелец.Номинал КАК NOMINAL,
	|ВЫБОР КОГДА АктивацияПодарочныхСертификатов.Статус = NULL ТОГДА 0
	|ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.НеАктивирован) ТОГДА 1  ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.Активирован) ТОГДА 2   ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.Аннулирован) ТОГДА 3  ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.ЧастичноПогашен) ТОГДА 4  ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.Возвращен) ТОГДА 5 ИНАЧЕ
	| ВЫБОР КОГДА  АктивацияПодарочныхСертификатов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПодарочныхСертификатов.ПолностьюПогашен) ТОГДА 6  ИНАЧЕ      
	| 0 КОНЕЦ
	|  КОНЕЦ
	| КОНЕЦ
	| КОНЕЦ
	| КОНЕЦ  
	| КОНЕЦ
	| КОНЕЦ КАК IDSTATUS,
	|АктивацияПодарочныхСертификатов.Статус КАК STATUS,
	|ОстаткиСертификатов.СуммаОстаток КАК BALANCE
	|ИЗ Справочник.ПодарочныеСертификаты КАК СпрСерт
	|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияПодарочныхСертификатов.СрезПоследних КАК АктивацияПодарочныхСертификатов 
	| ПО  АктивацияПодарочныхСертификатов.ПодарочныйСертификат = СпрСерт.Ссылка
	|ЛЕВОЕ СОЕДИНЕНИЕ  ОстаткиСертификатов КАК ОстаткиСертификатов ПО  СпрСерт.Ссылка=ОстаткиСертификатов.ПодарочныйСертификат
	|

	|";   
	Результат = Запрос.Выполнить().Выгрузить();

	Для каждого стр из  Результат Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр); 
		// СК.Вставить("IDS",СК.ID.УникальныйИдентификатор());
		МассивДанных.Добавить(СК);
	КонецЦикла;
	
КонецПроцедуры
Функция ДанныеСертификата_Т(МассивДанных)
		
	Поток = Новый ПотокВПамяти;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ПроверятьСтруктуру = Ложь; // 'Истина' только во время отладки
	ЗаписьJSON.ОткрытьПоток(Поток,,, Новый ПараметрыЗаписиJSON(, Символы.Таб));
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("Vouchers");
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
	Для каждого эл из МассивДанных Цикл
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		Для каждого ск из эл Цикл
			Значение = ск.Значение;
			Если НЕ ТипЗнч(Значение) = Тип("Строка") 
				ИЛИ  НЕ ТипЗнч(Значение) = Тип("Число") 
				ИЛИ НЕ ТипЗнч(Значение) = Тип("Булево") Тогда
				Значение = Строка(Значение);
			КонецЕсли;
			ЗаписьJSON.ЗаписатьИмяСвойства(ск.Ключ);
			ЗаписьJSON.ЗаписатьЗначение(Значение);
		КонецЦикла;	
		ЗаписьJSON.ЗаписатьКонецОбъекта();
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();  
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	ЗаписьJSON.Закрыть();
	
	СтрокаJSON = ПолучитьСтрокуИзДвоичныхДанных(Поток.ЗакрытьИПолучитьДвоичныеДанные(),"UTF-8");  
	//СтрокаJSON = СтрЗаменить(СтрЗаменить(СтрокаJSON,Символы.ПС,""),Символы.ВК,"");   
	
	//СтрокаJSON = СтрЗаменить(СтрокаJSON,Символы.ВТаб,"");  
	//СтрокаJSON = СтрЗаменить(СтрокаJSON,"\","");
	
    Возврат СтрокаJSON;
КонецФункции                                                                             

