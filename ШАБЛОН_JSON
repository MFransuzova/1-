&НаСервере
Функция ВернутьТекстJSON(МассивJSON)
	
	Поток = Новый ПотокВПамяти;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ПроверятьСтруктуру = Ложь; // 'Истина' только во время отладки
	ЗаписьJSON.ОткрытьПоток(Поток,,, Новый ПараметрыЗаписиJSON(, Символы.Таб));
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("Сертификаты");
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
	//Для Каждого Ссылка Из МассивДанных Цикл // так не надо делать!
	//Выборка = МассивJSON;
	Для каждого эл из МассивJSON Цикл
		//СериализаторXDTO.ЗаписатьJSON(ЗаписьJSON, эл, НазначениеТипаXML.Явное);
		// Либо ЗаписатьJSON(ЗаписьJSON,...) для низкоуровневой сериализации по способу №1   
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		Для каждого ск из эл Цикл
			Значение = ск.Значение;
			Если НЕ ТипЗнч(Значение) = Тип("Строка") 
				ИЛИ  НЕ ТипЗнч(Значение) = Тип("Число") 
				ИЛИ НЕ ТипЗнч(Значение) = Тип("Булево") Тогда
				Значение = Строка(Значение);
			КонецЕсли;
			ЗаписьJSON.ЗаписатьИмяСвойства(ск.Ключ);
			ЗаписьJSON.ЗаписатьЗначение(Значение);
		КонецЦикла;	
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();  
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	ЗаписьJSON.Закрыть();
	
	СтрокаJSON = ПолучитьСтрокуИзДвоичныхДанных(Поток.ЗакрытьИПолучитьДвоичныеДанные());

	Возврат СтрокаJSON;
КонецФункции

&НаСервере
Процедура ПостроитьТаблицуДанныхJSON(ДанныеГостя)   
	Сообщение = новый СообщениеПользователю;
	Сообщение.Текст = ВернутьТекстJSON(ДанныеГостя);
	Сообщение.Сообщить();
КонецПроцедуры

&НаСервере
Процедура ПостроитьТаблицуДанных(ДанныеГостя)    
	тзТаблицаЗапроса=Новый ТаблицаЗначений;
	Если НЕ ЭтаФорма.Элементы.Найти("РезультатЗапроса") = Неопределено Тогда  
		ЭтаФорма.РезультатЗапроса.Очистить();   
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				тзТаблицаЗапроса.Колонки.Добавить(св.Ключ);
			КонецЦикла;
			Прервать;
		КонецЦикла;
		
	Иначе 
		
		МассивТипаВыбора = Новый Массив;      
		МассивТипаВыбора.Добавить(Тип("ТаблицаЗначений"));  
		
		ОписаниеТипаВыбораТаблицаЗначений = Новый ОписаниеТипов(МассивТипаВыбора);		
		
		МассивРеквизитов = Новый Массив;
		
		РеквизитТаблица = Новый РеквизитФормы("РезультатЗапроса", ОписаниеТипаВыбораТаблицаЗначений,,"Данные вывода");
		
	//__________________________________________________
	//__________________________________________________
		
		МассивТипаВыбора = Новый Массив;
		
		МассивТипаВыбора.Добавить(Тип("Строка"));  	  
		МассивТипаВыбора.Добавить(Тип("Число")); 
		МассивТипаВыбора.Добавить(Тип("СправочникСсылка.ПодарочныеСертификаты"));

		ОписаниеТипаВыбораСтрока = Новый ОписаниеТипов(МассивТипаВыбора);	
		
		
		МассивРеквизитов.Добавить(РеквизитТаблица);
		
		
		//
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				Колонка = Новый РеквизитФормы(св.Ключ, ОписаниеТипаВыбораСтрока, "РезультатЗапроса", Строка(св.Ключ));
				МассивРеквизитов.Добавить(Колонка);   
				
				тзТаблицаЗапроса.Колонки.Добавить(св.Ключ);
				
			КонецЦикла;
			Прервать;
		КонецЦикла;
		
		ЭтаФорма.ИзменитьРеквизиты(МассивРеквизитов);
		
		ЭлементТовары = ЭтаФорма.Элементы.Добавить("РезультатЗапроса",Тип("ТаблицаФормы"));
		ЭлементТовары.ПутьКДанным = "РезультатЗапроса";
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				Попытка
					ЭлементДанные = ЭтаФорма.Элементы.Добавить("ТЕСТ"+св.Ключ,Тип("ПолеФормы"),ЭлементТовары);
					ЭлементДанные.Вид = ВидПоляФормы.ПолеВвода;
					ЭлементДанные.ПутьКДанным = "РезультатЗапроса."+Строка(св.Ключ);
				Исключение
					Сообщить("св.Ключ:"+св.Ключ) ;
				КонецПопытки;
				
			КонецЦикла;
			Прервать;
		КонецЦикла;   
	КонецЕсли ; 	
	Для каждого элМ из ДанныеГостя Цикл    
		стрГостя= тзТаблицаЗапроса.Добавить();
		Для каждого св из элМ Цикл    
			Попытка
				стрГостя[св.Ключ]=св.Значение;
			Исключение
				Сообщить("св.Ключ:"+св.Ключ) ;
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;  
	
	ЗначениеВРеквизитФормы(тзТаблицаЗапроса, "РезультатЗапроса");
	
КонецПроцедуры


&НаСервере
Процедура ВыгрузитьСертификатыНаСервере()  
	
	// 22.05.2026 1:09 X2
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ  
	|УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СпрСерт.Ссылка) КАК ID,
	|СпрСерт.Код КАК KODS,
	|СпрСерт.Наименование КАК NAMES,
    |СпрСерт.Штрихкод КАК BARCODECODE, 
	|СпрСерт.МагнитныйКод КАК МагнитныйКод,
	|СпрСерт.Владелец.Номинал КАК NOMINAL,
	|NULL  КАК IDStatus,
	|АктивацияПодарочныхСертификатов.Статус КАК Статус
	|ИЗ Справочник.ПодарочныеСертификаты КАК СпрСерт
	|ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияПодарочныхСертификатов.СрезПоследних КАК АктивацияПодарочныхСертификатов 
	|ПО  АктивацияПодарочныхСертификатов.ПодарочныйСертификат = СпрСерт.Ссылка
	|";   
	Результат = Запрос.Выполнить().Выгрузить(); 
	МассивДанных = Новый Массив;
	Для каждого стр из  Результат Цикл
		 СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр); 
		// СК.Вставить("IDS",СК.ID.УникальныйИдентификатор());
		 МассивДанных.Добавить(СК);
	КонецЦикла;
	
	ПостроитьТаблицуДанных(МассивДанных) ;  
	ПостроитьТаблицуДанныхJSON(МассивДанных) ;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьСертификаты(Команда)
	ВыгрузитьСертификатыНаСервере();
КонецПроцедуры
