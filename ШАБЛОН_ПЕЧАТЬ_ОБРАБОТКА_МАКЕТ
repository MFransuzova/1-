&НаСервере
Процедура ДанныеДляПечати(СтруктураДанных)
	Если НЕ СтруктураДанных.Свойство("Гость") Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СтруктураДанных.Гость) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|Гости.Ссылка КАК Гость
	|ИЗ Справочник.Картотека КАК Гости
	|ГДЕ Гости.Ссылка = &Гость
	|";
	Запрос.УстановитьПараметр("Гость",СтруктураДанных.Гость);
	Результат = Запрос.Выполнить().Выгрузить();
	МассивДанныеГостей = Новый Массив;
	Для каждого стр из Результат Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр); 
		МассивДанныеГостей.Добавить(СК); 
		СтруктураДанных.Вставить("ДанныеГостя",СК);
	КонецЦикла;                         
		
КонецПроцедуры

&НаСервере
Процедура ЛистНазначенияНаСервере(СтруктураДанных)   
	ТабличныйДокумент = СтруктураДанных.ТД; 
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЛистНазначенияДляГостя"; 
	Обработка =  РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ЛистНазначения");
	ДанныеДляПечати(СтруктураДанных);   
	Если НЕ СтруктураДанных.Свойство("ДанныеГостя") Тогда
		Возврат;
	КонецЕсли; 
	ДанныеГостя = СтруктураДанных.ДанныеГостя;
	ОбластиПечати = Новый Массив; 
	ОбластиПечати.Добавить("Шапка");  
	ОбластиПечати.Добавить("ТаблицаШапка1");
	ОбластиПечати.Добавить("ТаблицаСтроки1");
	ОбластиПечати.Добавить("ТаблицаПодвал1");
	ОбластиПечати.Добавить("ТаблицаШапка2");
	ОбластиПечати.Добавить("ТаблицаСтроки2");
	ОбластиПечати.Добавить("ТаблицаПодвал2"); 
	ОбластиПечати.Добавить("Подвал");
	СтруктураДанных = Новый Структура;
	СтруктураПеременных = Новый Структура;
	Для каждого эл из ОбластиПечати Цикл      
		СтруктураПеременных.Вставить("Область_"+Строка(эл),Макет.ПолучитьОбласть(эл));
	КонецЦикла;  
	Для каждого ск из СтруктураПеременных Цикл 
		ЗаполнитьЗначенияСвойств(ск.Значение.Параметры,ДанныеГостя);
	КонецЦикла;
	Для каждого ск из СтруктураПеременных Цикл 
		ТабличныйДокумент.Вывести(ск.Значение);
	КонецЦикла;
	СтруктураДанных.Вставить("ТД",ТабличныйДокумент);
	
КонецПроцедуры

&НаКлиенте
Процедура ЛистНазначения(Команда)
	ТД = Новый ТабличныйДокумент;
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ТД",ТД);   
	СтруктураДанных.Вставить("Гость",Объект.Гость);
	ЛистНазначенияНаСервере(СтруктураДанных); 
	Идентификатор = "ЛистНазначенияДляГостя";
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(Идентификатор);
	ОписаниеПечатнойФормы = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
	ОписаниеПечатнойФормы.ТабличныйДокумент = СтруктураДанных.ТД;
	
	// открытие общей формы Печати документов 
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,,ЭтаФорма); 
КонецПроцедуры
