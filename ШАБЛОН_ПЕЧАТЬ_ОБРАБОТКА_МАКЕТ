
&НаСервере
Процедура ДанныеДляПечати(СтруктураДанных)
	Если НЕ СтруктураДанных.Свойство("Гость") Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СтруктураДанных.Гость) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|Гости.Ссылка КАК Гость,
	|Гости.Код КАК НомерГостя 
	|ПОМЕСТИТЬ Гости
	|ИЗ Справочник.Картотека КАК Гости 
	
	|ГДЕ Гости.Ссылка = &Гость 
	|;
	|ВЫБРАТЬ  РАЗЛИЧНЫЕ ПЕРВЫЕ 1 
	|   	РегистрСтатусыУслуг.Заказ КАК Заказ  ,  
	|   	ТИПЗНАЧЕНИЯ(РегистрСтатусыУслуг.Заказ) КАК ТипЗаказа , 
	|   	РегистрСтатусыУслуг.Пациент КАК Пациент
	|   ПОМЕСТИТЬ втСтатусыУслуг
	|   ИЗ
	|   	РегистрСведений.СтатусыУслуг КАК РегистрСтатусыУслуг
	|   ГДЕ
	|   	РегистрСтатусыУслуг.Пациент В (ВЫБРАТЬ Гости.Гость ИЗ Гости КАК Гости)  
	|   //	И  РегистрСтатусыУслуг.Заказ.Номер ПОДОБНО &Номер
	|   	УПОРЯДОЧИТЬ ПО
	|   РегистрСтатусыУслуг.Заказ.Дата УБЫВ	
	|   ;     
	|   ВЫБРАТЬ                         
	|   ЗП.Ссылка, 
	|   ЗП.Ссылка.Номер КАК НомерЗаказа,
	|   ЗП.Ссылка.Пациент,              
	|   ЗП.Номенклатура,
	|   1 КАК Количество,
	|   ЗП.УникальныйИдентификаторУслуги,
	|   ЗП.ЗапланированноеВремя КАК ДатаПроцедуры,
	|   ЗП.МедицинскоеРабочееМесто КАК Кабинет 
	|   ПОМЕСТИТЬ УслугиЗаказов
	|   ИЗ Документ.ЗаказПациента.МедицинскиеУслуги КАК ЗП
	|   ГДЕ ЗП.Ссылка В (ВЫБРАТЬ втСтатусыУслуг.Заказ ИЗ втСтатусыУслуг КАК втСтатусыУслуг) 
	|;
	| ВЫБРАТЬ   
	| Данные.НомерЗаказа КАК НомерЗаказа,
	| Данные.Пациент КАК Гость,
	| Данные.Пациент.Код КАК НомерГостя,
	| Данные.Номенклатура КАК Процедура,
	| СУММА(Данные.Количество) КАК Количество
	|ИЗ УслугиЗаказов КАК Данные 
	|СГРУППИРОВАТЬ ПО   
	| Данные.НомерЗаказа,
	| Данные.Пациент,
	| Данные.Пациент.Код,
	| Данные.Номенклатура	
	|";
	Запрос.УстановитьПараметр("Гость",СтруктураДанных.Гость);  
	Пакет = Запрос.ВыполнитьПакетСПромежуточнымиДанными();  
	Расписание =Пакет[2].Выгрузить(); 
	Результат = Пакет[3].Выгрузить();
	МассивДанныеГостей = Новый Массив; 
	ВидыПроцедур = Новый Массив;
	Для каждого стр из Результат Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр); 
		МассивДанныеГостей.Добавить(СК);    
		ВидыПроцедур.Добавить(СК);
		СтруктураДанных.Вставить("ДанныеГостя",СК);
	КонецЦикла;                         
	СтруктураДанных.Вставить("ВидыПроцедур",ВидыПроцедур); 
	РасписаниеПроцедур = Новый Массив;
	Для каждого стр из Расписание Цикл
		СК = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(стр); 
		РасписаниеПроцедур.Добавить(СК);
	КонецЦикла; 	
	СтруктураДанных.Вставить("РасписаниеПроцедур",РасписаниеПроцедур);
	
	СтруктураДанных.Вставить("ВсегоПроцедур",Результат.Итог("Количество"));
КонецПроцедуры

&НаСервере
Процедура ЛистНазначенияНаСервере(СтруктураДанных)   
	ТабличныйДокумент = СтруктураДанных.ТД; 
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЛистНазначенияДляГостя"; 
	Обработка =  РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ЛистНазначения");    	
	ДанныеДляПечати(СтруктураДанных);   
	Если НЕ СтруктураДанных.Свойство("ДанныеГостя") Тогда
		Возврат;
	КонецЕсли;    
	
	ДанныеГостя = СтруктураДанных.ДанныеГостя; 
	РасписаниеПроцедур = Новый Массив; 
	ВидыПроцедур =  СтруктураДанных.ВидыПроцедур;    
	РасписаниеПроцедур =  СтруктураДанных.РасписаниеПроцедур;
	ДанныеГостя.Вставить("Специалист",ОбщиеМеханизмыКлиентСервер.ПолучитьФамилиюИнициалы(Пользователи.ТекущийПользователь()));    
	ДанныеГостя.Вставить("ВсегоПроцедур",СтруктураДанных.ВсегоПроцедур);

	ОбластиПечати = Новый Массив; 
	ОбластиПечати.Добавить("Шапка");  
	ОбластиПечати.Добавить("ТаблицаШапка1");
	ОбластиПечати.Добавить("ТаблицаСтроки1");
	ОбластиПечати.Добавить("ТаблицаПодвал1");
	ОбластиПечати.Добавить("ТаблицаШапка2");
	ОбластиПечати.Добавить("ТаблицаСтроки2");
	ОбластиПечати.Добавить("ТаблицаПодвал2"); 
	ОбластиПечати.Добавить("Подвал");
	СтруктураДанных = Новый Структура;
	СтруктураПеременных = Новый Структура;
	Для каждого эл из ОбластиПечати Цикл      
		СтруктураПеременных.Вставить("Область_"+Строка(эл),Макет.ПолучитьОбласть(эл));
	КонецЦикла;  
	Для каждого ск из СтруктураПеременных Цикл    
		ЗаполнитьЗначенияСвойств(ск.Значение.Параметры,ДанныеГостя);
	КонецЦикла;

	Для каждого ск из СтруктураПеременных Цикл    
		Если ск.Ключ =  "Область_ТаблицаСтроки2" Тогда 
			Для каждого эл из ВидыПроцедур Цикл  
				ЗаполнитьЗначенияСвойств(ск.Значение.Параметры,эл);
				ТабличныйДокумент.Вывести(ск.Значение);
			КонецЦикла; 
		ИначеЕсли ск.Ключ =  "Область_ТаблицаСтроки1" Тогда 
			Для каждого эл из РасписаниеПроцедур Цикл  
				ЗаполнитьЗначенияСвойств(ск.Значение.Параметры,эл);
				ТабличныйДокумент.Вывести(ск.Значение);
			КонецЦикла; 
	
		Иначе
		ТабличныйДокумент.Вывести(ск.Значение);  
		КонецЕсли;
	КонецЦикла;
	СтруктураДанных.Вставить("ТД",ТабличныйДокумент);
	
КонецПроцедуры

&НаКлиенте
Процедура ЛистНазначения(Команда)
	ТД = Новый ТабличныйДокумент;
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ТД",ТД);         
	СтруктураДанных.Вставить("Гость",Объект.Гость);   
	ЛистНазначенияНаСервере(СтруктураДанных); 
	Идентификатор = "ЛистНазначенияДляГостя";
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(Идентификатор);
	ОписаниеПечатнойФормы = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
	ОписаниеПечатнойФормы.ТабличныйДокумент = СтруктураДанных.ТД;
	
	// открытие общей формы Печати документов 
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,,ЭтаФорма); 
КонецПроцедуры
