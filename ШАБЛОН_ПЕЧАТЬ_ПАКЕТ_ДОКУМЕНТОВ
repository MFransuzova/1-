&НаСервере
Процедура ПечатьДляСборкиНаСервере(МассивПечатных,Общая_Объекты)  
	УстановитьПривилегированныйРежим(Истина);
	МассивПечати = Новый Массив;
	Для каждого стр из ТаблицаЗаказов Цикл
		Если стр.вк Тогда
			МассивПечати.Добавить(стр.Заказ);
		КонецЕсли;
	КонецЦикла;     
	Если МассивПечати.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВывода = Новый Структура;
	КомплектПечатныхФорм = ВернутьСтруктуруКоллекции();  
	МенеджерОбъекта = Обработки.ПечатьЗаданияНаОтборРазмещениеТоваров;     //ОбщегоНазначенияУТ.ПолучитьМодульЛокализации("ЗаказКлиента");
	Для каждого ОбъектПечати из МассивПечати Цикл
		СтруктураТипов = Новый Соответствие;   
		СтруктураТипов.Вставить("Документ.ЗаказКлиента", ОбъектПечати);   
		ПараметрыПечати = Новый Структура;   
		ПараметрыПечати.Вставить("ПечатьПоДаннымДокумента",Истина); 
		
		МассивОбъекта = Новый СписокЗначений;
		МассивОбъекта.Добавить(ОбъектПечати,Строка(ОбъектПечати)); 
		Общая_Объекты.Добавить(ОбъектПечати,Строка(ОбъектПечати));
		Макет = МенеджерОбъекта.СформироватьЗаданиеНаОтборРазмещениеТовара(СтруктураТипов,МассивОбъекта,ПараметрыПечати);
		СтруктураПФ = Новый Структура;
		СтруктураПФ.Вставить("Макет",Макет);  
		СтруктураПФ.Вставить("Синоним",Строка(ОбъектПечати));

		МассивПечатных.Добавить(СтруктураПФ);
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПечатьДляСборки(Команда)  
	МассивПечатных = Новый Массив;
	Общая_Объекты = Новый СписокЗначений;
	ПечатьДляСборкиНаСервере(МассивПечатных,Общая_Объекты);   
	к = 1;        
	КоллекцияПечатныхФормМ = Новый Массив;
	Для каждого эл из МассивПечатных Цикл 
		Идентификатор = "наш_Идентификатор_"+Строка(к);
		
		КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(Идентификатор);  
	
		ОписаниеПечатнойФормы = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, Идентификатор);
		ОписаниеПечатнойФормы.ТабличныйДокумент = эл.Макет;  
		ОписаниеПечатнойФормы.СинонимМакета = Строка(эл.Синоним); 
		КоллекцияПечатныхФормМ.Добавить(КоллекцияПечатныхФорм[0]);
		// открытие общей формы Печати документов 
		//УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,,ЭтаФорма); 
		к = к+1;
		//	эл.Показать();
	КонецЦикла;    
	мПараметрКоманды = Новый Массив; 
	
	ПараметрыПечати = Новый Структура("ПереопределитьПользовательскиеНастройкиКоличества", Истина);   
	КомплектыПечати = Новый Структура("КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрКоманды, ПараметрыПечати", КоллекцияПечатныхФормМ, Общая_Объекты, мПараметрКоманды, ПараметрыПечати);
    ОткрытьФорму("ОбщаяФорма.ПечатьДокументов", КомплектыПечати);
КонецПроцедуры
