&НаСервере
Процедура ПостроитьТаблицуДанных(ДанныеГостя)    
	тзТаблицаЗапроса=Новый ТаблицаЗначений;
	Если НЕ ЭтаФорма.Элементы.Найти("РезультатЗапроса") = Неопределено Тогда  
		ЭтаФорма.РезультатЗапроса.Очистить();   
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				тзТаблицаЗапроса.Колонки.Добавить(св.Ключ);
			КонецЦикла;
			Прервать;
		КонецЦикла;
		
	Иначе 
		
		МассивТипаВыбора = Новый Массив;      
		МассивТипаВыбора.Добавить(Тип("ТаблицаЗначений"));  
		
		ОписаниеТипаВыбораТаблицаЗначений = Новый ОписаниеТипов(МассивТипаВыбора);		
		
		МассивРеквизитов = Новый Массив;
		
		РеквизитТаблица = Новый РеквизитФормы("РезультатЗапроса", ОписаниеТипаВыбораТаблицаЗначений,,"Данные вывода");
		
		МассивТипаВыбора = Новый Массив;
		
		МассивТипаВыбора.Добавить(Тип("Строка"));  	  
		МассивТипаВыбора.Добавить(Тип("Число")); 
		МассивТипаВыбора.Добавить(Тип("СправочникСсылка.ПодарочныеСертификаты"));

		ОписаниеТипаВыбораСтрока = Новый ОписаниеТипов(МассивТипаВыбора);	
		
		
		МассивРеквизитов.Добавить(РеквизитТаблица);
		
		
		//
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				Колонка = Новый РеквизитФормы(св.Ключ, ОписаниеТипаВыбораСтрока, "РезультатЗапроса", Строка(св.Ключ));
				МассивРеквизитов.Добавить(Колонка);   
				
				тзТаблицаЗапроса.Колонки.Добавить(св.Ключ);
				
			КонецЦикла;
			Прервать;
		КонецЦикла;
		
		ЭтаФорма.ИзменитьРеквизиты(МассивРеквизитов);
		
		ЭлементТовары = ЭтаФорма.Элементы.Добавить("РезультатЗапроса",Тип("ТаблицаФормы"));
		ЭлементТовары.ПутьКДанным = "РезультатЗапроса";
		Для каждого элМ из ДанныеГостя Цикл    
			Для каждого св из элМ Цикл    
				Попытка
					ЭлементДанные = ЭтаФорма.Элементы.Добавить("ТЕСТ"+св.Ключ,Тип("ПолеФормы"),ЭлементТовары);
					ЭлементДанные.Вид = ВидПоляФормы.ПолеВвода;
					ЭлементДанные.ПутьКДанным = "РезультатЗапроса."+Строка(св.Ключ);
				Исключение
					Сообщить("св.Ключ:"+св.Ключ) ;
				КонецПопытки;
				
			КонецЦикла;
			Прервать;
		КонецЦикла;   
	КонецЕсли ; 	
	Для каждого элМ из ДанныеГостя Цикл    
		стрГостя= тзТаблицаЗапроса.Добавить();
		Для каждого св из элМ Цикл    
			Попытка
				стрГостя[св.Ключ]=св.Значение;
			Исключение
				Сообщить("св.Ключ:"+св.Ключ) ;
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;  
	
	ЗначениеВРеквизитФормы(тзТаблицаЗапроса, "РезультатЗапроса");
	
КонецПроцедуры
